# The `files` array in package.json is the source of truth for what ships.
# This file is defense-in-depth — exclude things that could otherwise leak
# from inside a whitelisted directory (e.g. node_modules inside examples/).

**/node_modules
**/node_modules/**
.DS_Store
*.log
coverage/
.vitest/
.vscode/
.idea/
*.test.ts
*.spec.ts
