{
  "name": "@orckit/cli",
  "version": "0.2.0",
  "description": "Lean CLI process orchestrator for local development environments",
  "keywords": [
    "orchestration",
    "process-manager",
    "development",
    "local-dev",
    "workflow"
  ],
  "homepage": "https://github.com/dominicbartl/orckit#readme",
  "bugs": {
    "url": "https://github.com/dominicbartl/orckit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominicbartl/orckit.git"
  },
  "license": "MIT",
  "author": "Dominic Bartl",
  "type": "module",
  "bin": {
    "orc": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "examples",
    "!examples/**/node_modules",
    "!examples/**/node_modules/**",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "dev:web": "pnpm --filter @orckit/web-ui dev",
    "build": "rm -rf dist && tsc && pnpm build:web",
    "build:web": "pnpm --filter @orckit/web-ui build && mkdir -p dist/web/static && cp -R packages/web-ui/dist/. dist/web/static/",
    "postbuild": "chmod +x dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests --exclude tests/integration/**",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "execa": "^9.6.0",
    "js-yaml": "^4.1.0",
    "tree-kill": "^1.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
